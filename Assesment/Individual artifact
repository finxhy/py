import json 
import os

file = "tasks.json"
list = []

def load_tasks(): #loads tasks from a data set 
    global list
    if os.path.exists("tasks.json"):
            try:
                with open("tasks.json", 'r') as f:
                    list = json.load(f)
            except json.JSONDecodeError:
                print("Error: The tasks file is corrupted. Starting with an empty list.") #co pilot suggested this to reset if the file is corrupted, prevents crashing and allows user to start fresh
                list = []
    else:
        list = []
        
        
        
def save_tasks(): #saves tasks to a data set
    with open(file, 'w') as f:
        json.dump(list, f, indent=4) 

#display the list of tasks
def tasks():
   print("To do list")
   if not list:
       print("Your list is currently empty.")
   else:
       for index, task in enumerate(list, start=1): #used AI to come out with this line, it adds numbers to the list of tasks and cleans up the UI 
           print(f"{index}. [ ] {task}")
   

def add_task():
   #Adds a new item to the list
   task = input("What do you need to do? ")
   list.append(task)
   save_tasks()
   print(f"Added: '{task}'")


def remove_task():
   #Removes an item by its number
   tasks()
   if list:
       try:
           task_num = int(input("Enter the task number to remove: "))
           #Checks if the number is valid
           if 1 <= task_num <= len(list):
               removed = list.pop(task_num - 1)
               save_tasks()
               print(f"Removed: '{removed}'")
           else:
               print("Invalid number.")
       except ValueError:
           print("Please enter a valid digit.") 
           
           
def main():
   load_tasks()
   #handles user input(loops until user exits)
   while True:
       print("1. View tasks")
       print("2. Add Task")
       print("3. Remove Task")
       print("4. Exit")
      
       choice = input("Select an option (1-4): ")


       #Routes user input to functions printed above 
       if choice == '1':
           tasks()
       elif choice == '2':
           add_task()
       elif choice == '3':
           remove_task()
       elif choice == '4':
           print("Cleaning up... Goodbye!")
           break
       else:
           print("That's not a valid option, try again.")


if __name__ == "__main__":
   main()

           




